{
  "manifest_version": 3,
  "name": "GexSync",
  "version": "1.0",
  "description": "Sync gex/options profile (90d/latest/next) across GEXbot tabs, tickers stay independent.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.gexbot.com/*"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{
    "matches": ["https://www.gexbot.com/state*", "https://www.gexbot.com/classic*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
